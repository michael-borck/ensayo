{% extends "base.html.j2" %}
{% block title %}{{ listing_title }} — {{ site.company.name }}{% endblock %}

{% block content %}
<section class="section">
    <h1>{{ listing_title }}</h1>

    {% if documents %}
    <div class="card-grid">
        {% for doc in documents %}
        <a href="{{ base_url }}docs/{{ doc.category }}/{{ doc.slug }}.html" class="card card-link">
            <h3>{{ doc.title }}</h3>
        </a>
        {% endfor %}
    </div>
    {% else %}
    <p>No documents available.</p>
    {% endif %}
</section>
{% endblock %}
