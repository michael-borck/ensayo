{% extends "base.html.j2" %}
{% block title %}{{ site.company.name }} — {{ site.company.tagline }}{% endblock %}

{% block content %}
<section class="hero">
    <h1>{{ site.company.name }}</h1>
    {% if site.company.tagline %}
    <p class="hero-tagline">{{ site.company.tagline }}</p>
    {% endif %}
</section>

{% if content.employees %}
<section class="section">
    <h2>Our Team</h2>
    <div class="card-grid">
        {% for emp in content.employees[:4] %}
        <a href="{{ base_url }}chatbots/{{ emp.slug }}/index.html" class="card card-link">
            <h3>{{ emp.name }}</h3>
            <p class="card-role">{{ emp.role }}</p>
        </a>
        {% endfor %}
    </div>
    {% if content.employees|length > 4 %}
    <p class="section-more"><a href="{{ base_url }}chatbots/index.html">View all staff &rarr;</a></p>
    {% endif %}
</section>
{% endif %}

{% if content.support_docs %}
<section class="section">
    <h2>Resources</h2>
    <div class="card-grid">
        {% for doc in content.support_docs[:3] %}
        <a href="{{ base_url }}docs/support/{{ doc.slug }}.html" class="card card-link">
            <h3>{{ doc.title }}</h3>
        </a>
        {% endfor %}
    </div>
    <p class="section-more"><a href="{{ base_url }}docs/support/index.html">View all documents &rarr;</a></p>
</section>
{% endif %}
{% endblock %}
